{
  "name": "web-todo-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Workspace scripts for frontend/backend todo app",
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "dev": "concurrently -k \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm --prefix frontend run build",
    "preview": "npm --prefix frontend run preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyungjini/web-todo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kyungjini/web-todo/issues"
  },
  "homepage": "https://github.com/kyungjini/web-todo#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "mongoose": "^9.3.3"
  }
}
